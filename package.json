{
  "name": "linkserver",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm /dev:.*/",
    "dev:build": "esbuild dev.ts ./src --bundle --outdir=dist --packages=external --format=esm --platform=node --sourcemap --watch",
    "dev:run": "node --inspect --no-warnings --loader ./dist/dev.js --watch dist/src",
    "build": "esbuild index=./src --bundle --minify --outdir=dist --packages=external --format=esm --platform=node",
    "start": "node dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "esbuild": "^0.25.8",
    "nanoid": "^5.1.5",
    "pnpm": "^10.14.0",
    "socket.io": "^4.8.1",
    "true-myth": "^9.1.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
